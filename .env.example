# Required: real model key (default agent model is openai/gpt-4o-mini)
OPENAI_API_KEY=
# Optional: only needed if switching to the claude model
ANTHROPIC_API_KEY=
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=acme
KEYCLOAK_CLIENT_ID=acme-api
KEYCLOAK_CLIENT_SECRET=acme-api-secret
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/acme
REDIS_URL=redis://localhost:6379
LITELLM_URL=http://localhost:4000
# Must match master_key in infra/litellm/config.yaml (not a secret)
LITELLM_API_KEY=sk-acme-master-key
MCP_SERVER_URL=http://localhost:8001/mcp
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=acme-agent
# Set true to run LLM-judge eval scoring (faithfulness + reasonableness) in the eval CLI
RAGAS_ENABLED=false
# Judge for faithfulness + recommendation reasonableness. gpt-4o by default
# (reproducible with the required OpenAI key, reliable with RAGAS). For a
# cross-family judge that avoids same-family self-preference bias vs the
# gpt-4o-mini agent, set EVAL_JUDGE_MODEL=claude-sonnet-4 (needs ANTHROPIC_API_KEY).
EVAL_JUDGE_MODEL=gpt-4o
