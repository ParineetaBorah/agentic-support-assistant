{
  "realm": "acme",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "roles": {
    "realm": [
      {
        "name": "sales_user",
        "description": "Read-only access to customer and issue data",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "support_user",
        "description": "Read and update access for issues",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "admin",
        "description": "Full access including creating and updating next actions",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "acme-api",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "acme-api-secret",
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "acme-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "id": "b1000000-0000-0000-0000-000000000001",
      "username": "alice",
      "email": "alice@acme.com",
      "firstName": "Alice",
      "lastName": "Sales",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": ["sales_user"]
    },
    {
      "id": "b1000000-0000-0000-0000-000000000002",
      "username": "bob",
      "email": "bob@acme.com",
      "firstName": "Bob",
      "lastName": "Support",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": ["support_user"]
    },
    {
      "id": "b1000000-0000-0000-0000-000000000003",
      "username": "carol",
      "email": "carol@acme.com",
      "firstName": "Carol",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    }
  ]
}
